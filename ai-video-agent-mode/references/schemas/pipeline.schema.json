{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Video Agent Mode Pipeline Schema",
  "description": "Pipeline data structures for ai-video-agent-mode",
  "definitions": {
    "shot_plan": {
      "type": "object",
      "properties": {
        "project_name": {"type": "string"},
        "total_shots": {"type": "integer"},
        "shots": {
          "type": "array",
          "items": {"$ref": "#/definitions/shot"}
        }
      },
      "required": ["project_name", "total_shots", "shots"]
    },
    "shot": {
      "type": "object",
      "properties": {
        "shot_id": {"type": "string", "pattern": "^S\\d+-\\d+$"},
        "scene": {"type": "string"},
        "total_duration": {"type": "number"},
        "core_action": {"type": "string"},
        "subshots": {
          "type": "array",
          "items": {"$ref": "#/definitions/subshot"}
        }
      },
      "required": ["shot_id", "scene", "total_duration", "subshots"]
    },
    "subshot": {
      "type": "object",
      "properties": {
        "subshot_id": {"type": "string", "pattern": "^S\\d+-\\d+-\\d+$"},
        "duration": {"type": "number"},
        "shot_size": {"type": "string"},
        "base_action": {"type": "string"},
        "shot_type": {"type": "string"},
        "visual_intent": {"type": "string"},
        "image_subject": {"type": "string"},
        "atmosphere": {"type": "string"},
        "characters": {"type": "array", "items": {"type": "string"}},
        "dialogue_refs": {"type": "array", "items": {"type": "string"}},
        "emotion_tone": {"type": "string"},
        "dramatic_design": {"type": "object"},
        "duration_design": {"type": "object"}
      },
      "required": ["subshot_id", "duration"]
    },
    "director_packet": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {"$ref": "#/definitions/director_item"}
        }
      },
      "required": ["items"]
    },
    "scene_lock_package": {
      "type": "object",
      "properties": {
        "scenes": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/definitions/scene_lock"}
        }
      },
      "required": ["scenes"],
      "additionalProperties": false
    },
    "scene_lock": {
      "type": "object",
      "properties": {
        "scene": {"type": "string", "minLength": 1},
        "space_anchor": {"type": "string", "minLength": 1},
        "screen_positions": {"type": "string", "minLength": 1},
        "wardrobe_lock": {"type": "string", "minLength": 1},
        "prop_state": {"type": "string", "minLength": 1},
        "light_source": {"type": "string", "minLength": 1},
        "light_direction": {"type": "string", "minLength": 1},
        "light_temperature": {"type": "string", "minLength": 1},
        "audio_policy": {"type": "string", "minLength": 1}
      },
      "required": ["scene", "space_anchor", "screen_positions", "wardrobe_lock", "prop_state", "light_source", "light_direction", "light_temperature", "audio_policy"],
      "additionalProperties": false
    },
    "director_item": {
      "type": "object",
      "properties": {
        "shot_id": {"type": "string"},
        "subshot_id": {"type": "string"},
        "duration": {"type": "number"},
        "shot_size": {"type": "string"},
        "camera_position": {"type": "string"},
        "camera": {"type": "string"},
        "axis_space": {"type": "string"},
        "visible_characters": {"type": "string"},
        "character_action": {"type": "string"},
        "dialogue_audio": {"type": "string"},
        "dialogue_refs": {"type": "array", "items": {"type": "string"}},
        "dialogue_raw_text": {"type": "string"},
        "lighting": {"type": "string"},
        "char_entry_exit": {"type": "string"},
        "axis_start": {"type": "string"},
        "axis_end": {"type": "string"},
        "movement_type": {"type": "string"},
        "movement_detail": {"type": "string"},
        "end_state": {"type": "string"},
        "full_prompt": {"type": "string"}
      },
      "required": ["shot_id", "subshot_id", "duration", "shot_size", "camera_position", "camera", "axis_space", "character_action", "dialogue_audio", "lighting", "end_state"]
    },
    "prompt_package": {
      "type": "object",
      "properties": {
        "contract_version": {"const": "jimeng-t2v-v1"},
        "shots": {
          "type": "array",
          "items": {"$ref": "#/definitions/prompt_item"}
        }
      },
      "required": ["contract_version", "shots"],
      "additionalProperties": false
    },
    "prompt_item": {
      "type": "object",
      "properties": {
        "shot_id": {"type": "string"},
        "subshot_id": {"type": "string"},
        "duration": {"type": "number"},
        "shot_size": {"type": "string"},
        "camera_position": {"type": "string"},
        "camera": {"type": "string"},
        "axis_space": {"type": "string"},
        "character_action": {"type": "string"},
        "lighting": {"type": "string"},
        "audio_design": {"type": "string"},
        "full_prompt": {"type": "string"},
        "negative_prompt": {"type": "string"},
        "qa_metadata": {"type": "object"},
        "generation_control": {"type": "object"}
      },
      "required": ["shot_id", "subshot_id", "duration", "full_prompt", "negative_prompt", "qa_metadata", "generation_control"]
    }
  }
}
