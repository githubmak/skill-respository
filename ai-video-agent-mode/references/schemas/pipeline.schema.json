{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Video Agent Mode Pipeline Schema",
  "description": "Pipeline data structures for ai-video-agent-mode",
  "definitions": {
    "shot_plan": {
      "type": "object",
      "properties": {
        "project_name": {"type": "string"},
        "total_shots": {"type": "integer"},
        "shots": {
          "type": "array",
          "items": {"$ref": "#/definitions/shot"}
        }
      },
      "required": ["project_name", "total_shots", "shots"]
    },
    "shot": {
      "type": "object",
      "properties": {
        "shot_id": {"type": "string", "pattern": "^S\\d+-\\d+$"},
        "scene": {"type": "string"},
        "total_duration": {"type": "number"},
        "core_action": {"type": "string"},
        "subshots": {
          "type": "array",
          "items": {"$ref": "#/definitions/subshot"}
        }
      },
      "required": ["shot_id", "scene", "total_duration", "subshots"]
    },
    "subshot": {
      "type": "object",
      "properties": {
        "subshot_id": {"type": "string", "pattern": "^S\\d+-\\d+-\\d+$"},
        "duration": {"type": "number"},
        "shot_size": {"type": "string"},
        "base_action": {"type": "string"},
        "shot_type": {"type": "string"},
        "visual_intent": {"type": "string"},
        "image_subject": {"type": "string"},
        "atmosphere": {"type": "string"},
        "characters": {"type": "array", "items": {"type": "string"}},
        "dialogue_refs": {"type": "array", "items": {"type": "string"}},
        "emotion_tone": {"type": "string"}
      },
      "required": ["subshot_id", "duration"]
    },
    "director_packet": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {"$ref": "#/definitions/director_item"}
        }
      },
      "required": ["items"]
    },
    "director_item": {
      "type": "object",
      "properties": {
        "shot_id": {"type": "string"},
        "subshot_id": {"type": "string"},
        "duration": {"type": "number"},
        "shot_size": {"type": "string"},
        "camera_position": {"type": "string"},
        "camera": {"$ref": "#/definitions/camera"},
        "axis_space": {"type": "string"},
        "composition": {"type": "string"},
        "character_action": {"type": "string"},
        "action_beats": {"$ref": "#/definitions/action_beats"},
        "micro_actions": {"type": "string"},
        "emotion": {"$ref": "#/definitions/emotion"},
        "dialogue_audio": {"$ref": "#/definitions/dialogue_audio"},
        "lighting": {"type": "string"},
        "audio_design": {"type": "string"},
        "negative_risks": {"type": "array", "items": {"type": "string"}},
        "commercial_quality": {"$ref": "#/definitions/commercial_quality"},
        "performance_plan": {"$ref": "#/definitions/performance_plan"}
      },
      "required": ["shot_id", "subshot_id", "duration"]
    },
    "camera": {
      "type": "object",
      "properties": {
        "lens": {"type": "string"},
        "angle": {"type": "string"},
        "movement": {"type": "string"},
        "axis": {"type": "string"},
        "transition": {"type": "string"},
        "virtual_camera": {"type": "string"}
      }
    },
    "action_beats": {
      "type": "object",
      "properties": {
        "start": {"type": "string"},
        "transition": {"type": "string"},
        "contact_or_peak": {"type": "string"},
        "end_state": {"type": "string"}
      }
    },
    "emotion": {
      "type": "object",
      "properties": {
        "cause": {"type": "string"},
        "expression_chain": {"type": "string"},
        "micro_expression": {"type": "string"},
        "psychology_flow": {"type": "string"},
        "performance_anchor": {"type": "string"}
      }
    },
    "dialogue_audio": {
      "type": "object",
      "properties": {
        "dialogue_refs": {"type": "array", "items": {"type": "string"}},
        "raw_text": {"type": "string"},
        "dubbing_text": {"type": "string"},
        "pause_plan": {"type": "string"},
        "mouth_visibility": {"type": "string"},
        "voice_performance": {"type": "string"},
        "timing": {"$ref": "#/definitions/timing"}
      }
    },
    "timing": {
      "type": "object",
      "properties": {
        "char_count": {"type": "integer"},
        "estimated_seconds": {"type": "number"},
        "available_seconds": {"type": "number"},
        "status": {"type": "string", "enum": ["ok", "tight", "over_limit"]}
      }
    },
    "commercial_quality": {
      "type": "object",
      "properties": {
        "camera_compatibility": {"type": "string"},
        "continuity_axis": {"type": "string"},
        "lighting_logic": {"type": "string"},
        "performance_specificity": {"type": "string"},
        "action_boundary": {"type": "string"},
        "shot_size_facing": {"type": "string"},
        "repair_notes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "performance_plan": {
      "type": "object",
      "properties": {
        "body_action": {"type": "string"},
        "facial_expression": {"type": "string"},
        "micro_actions": {"type": "string"},
        "voice_performance": {"type": "string"},
        "end_state": {"type": "string"}
      }
    },
    "prompt_package": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {"$ref": "#/definitions/prompt_item"}
        },
        "merged_full_prompts": {
          "type": "array",
          "items": {"$ref": "#/definitions/merged_prompt"}
        }
      }
    },
    "prompt_item": {
      "type": "object",
      "properties": {
        "shot_id": {"type": "string"},
        "subshot_id": {"type": "string"},
        "duration": {"type": "number"},
        "shot_size": {"type": "string"},
        "camera_position": {"type": "string"},
        "camera": {"type": "string"},
        "axis_space": {"type": "string"},
        "character_action": {"type": "string"},
        "lighting": {"type": "string"},
        "audio_design": {"type": "string"},
        "full_prompt": {"type": "string"}
      }
    },
    "merged_prompt": {
      "type": "object",
      "properties": {
        "shot_id": {"type": "string"},
        "duration": {"type": "number"},
        "full_prompt": {"type": "string"},
        "image_prompt": {"type": "string"},
        "video_prompt": {"type": "string"},
        "seedance_prompt": {"type": "string"},
        "full_video_prompt": {"type": "string"}
      }
    }
  }
}
